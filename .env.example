# Google Ads API credentials
# See: https://developers.google.com/google-ads/api/docs/oauth/cloud-project
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_CLIENT_ID=your_oauth_client_id_here
GOOGLE_ADS_CLIENT_SECRET=your_oauth_client_secret_here
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here
# MCC (manager) customer ID — digits only, no dashes
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890
# Default operating customer ID — overridable per-tool-call
GOOGLE_ADS_CUSTOMER_ID=1234567890
# google-ads client API version (omit to use library default; v24 is current as of google-ads 31.x)
GOOGLE_ADS_API_VERSION=v24

LOG_LEVEL=INFO
